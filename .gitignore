# Python 缓存
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/

# 数据集（关键：忽略原始数据）
datasets/

# 输出文件（避免上传大体积结果）
build/
runs/
outputs/
cropped_results/
detect_result/
patch_vis/
upper_detect_result/
artifacts/*
!artifacts/.gitkeep
demo_data/camera1/*
!demo_data/camera1/.gitkeep
demo_data/camera2/*
!demo_data/camera2/.gitkeep

# 模型权重（可选，大权重放 DVC/外链）
*.pt
*.pth
*.onnx
*.engine
*.torchscript
*.mlpackage
*.enc
*.key

# 系统缓存
.DS_Store
*.log
.idea/
.vscode/
.ruff_cache/
